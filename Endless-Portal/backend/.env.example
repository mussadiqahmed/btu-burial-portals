PORT=8000
NODE_ENV=development

# LOCAL development — use XAMPP MySQL on your Mac (NOT the live server)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=endless_eternity_memorials_system
DB_PORT=3306

# Production (cPanel endless_api/.env only — NEVER overwrite this file when deploying):
# DB_HOST=localhost
# DB_USER=endlesse_endlesse
# DB_PASSWORD=your-cpanel-mysql-password
# DB_NAME=endlesse_website
# DB_PORT=3306
# NODE_ENV=production

# --- Email (quotation PDF) — set on production API only ---
# SMTP_HOST=mail.eem.co.bw
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=quotes@eem.co.bw
# SMTP_PASS=your-cpanel-email-password
# SMTP_FROM — omit on cPanel (API uses SMTP_USER). If set, must be quoted:
# SMTP_FROM="Endless Eternity Memorials <quotes@eem.co.bw>"
